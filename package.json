{
  "name": "lawyertec-landing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "payload generate:importmap && next dev --hostname 127.0.0.1",
    "build": "payload generate:importmap && payload migrate && next build",
    "start": "next start",
    "lint": "eslint",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "generate:importmap": "payload generate:importmap",
    "payload": "payload",
    "seed": "payload migrate && payload seed"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.85.2",
    "@payloadcms/live-preview-react": "^3.85.2",
    "@payloadcms/next": "^3.85.2",
    "@payloadcms/richtext-lexical": "^3.85.2",
    "@payloadcms/storage-vercel-blob": "^3.85.2",
    "@supabase/supabase-js": "^2.110.0",
    "@vercel/analytics": "^2.0.1",
    "graphql": "^16.14.2",
    "next": "16.2.10",
    "payload": "^3.85.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
