# Supabase — project URL is safe to expose publicly
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Server-only — anon key for waitlist inserts (do NOT use service role here)
SUPABASE_ANON_KEY=your-anon-key

# REQUIRED in production — restrict waitlist API to your domain(s), comma-separated
# Without this, the waitlist endpoint accepts requests from any Origin header.
ALLOWED_ORIGINS=https://lawyertec.com,https://www.lawyertec.com

# Public site URL for SEO metadata, sitemap, canonical links, and Payload CORS/CSRF
NEXT_PUBLIC_SITE_URL=https://lawyertec.com

# Payload CMS — server-only (never prefix with NEXT_PUBLIC_)
#
# REQUIRED in production — app refuses to start without these:
#
# From Supabase → Connect:
# - Vercel/production: Direct connection (port 5432)
# - Local dev (if direct fails with EHOSTUNREACH): Session pooler (port 5432, IPv4)
#   Copy the full URI exactly — do not use "..." placeholders
DATABASE_URI=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
PAYLOAD_SECRET=generate-a-long-random-string-at-least-32-chars

# Vercel Blob — image uploads for carousel (create store in Vercel → Storage → Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional: Vercel Deploy Hook URL — triggers rebuild when CMS content is saved
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# Optional: explicit server URL for Payload Live Preview (defaults to NEXT_PUBLIC_SITE_URL or VERCEL_URL)
# NEXT_PUBLIC_SERVER_URL=https://lawyertec.com

# REQUIRED before first deploy — create the first admin user (closes /api/users/first-register)
# Run once after migrate: npm run seed
PAYLOAD_SEED_EMAIL=editor@lawyertec.com
PAYLOAD_SEED_PASSWORD=choose-a-strong-password
