# Supabase — project URL is safe to expose publicly
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Server-only — anon key for waitlist inserts (do NOT use service role here)
SUPABASE_ANON_KEY=your-anon-key

# Optional: restrict waitlist API to your production domain(s), comma-separated
# ALLOWED_ORIGINS=https://lawyertec.com,https://www.lawyertec.com

# Public site URL for SEO metadata, sitemap, and canonical links
NEXT_PUBLIC_SITE_URL=https://lawyertec.com
